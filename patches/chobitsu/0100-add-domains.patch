index 0000000..43c55d9
--- /dev/null
+++ b/src/domains/Accessibility.ts
@@ -0,0 +1,326 @@
+import * as nodeManager from '../lib/nodeManager'
+import trim from 'licia/trim'
+import each from 'licia/each'
+import Protocol from 'devtools-protocol'
+import Accessibility = Protocol.Accessibility
+
+// chrome-devtools-mcp (via puppeteer's `page.accessibility.snapshot()`) needs
+// this domain to build the text snapshot used by `take_snapshot` and to map
+// a11y nodes back to DOM nodes for clicking/typing. Chrome's real accessibility
+// tree is not reachable from JS, so we approximate it by
+// walking the DOM and computing ARIA roles and accessible names.
+
+function str(value: string): Accessibility.AXValue {
+  return { type: 'string' as Accessibility.AXValueType, value }
+}
+
+function bool(value: boolean): Accessibility.AXValue {
+  return { type: 'booleanOrUndefined' as Accessibility.AXValueType, value }
+}
+
+function collapse(text: string): string {
+  return trim(text.replace(/\s+/g, ' '))
+}
+
+function isHidden(el: Element): boolean {
+  if (el.getAttribute('aria-hidden') === 'true') return true
+  if ((el as HTMLElement).hidden) return true
+  try {
+    const style = window.getComputedStyle(el)
+    if (style.display === 'none' || style.visibility === 'hidden') return true
+  } catch (e) {
+    /* not stylable, ignore */
+  }
+  return false
+}
+
+function inputRole(el: HTMLInputElement): string {
+  switch ((el.getAttribute('type') || 'text').toLowerCase()) {
+    case 'button':
+    case 'submit':
+    case 'reset':
+    case 'image':
+      return 'button'
+    case 'checkbox':
+      return 'checkbox'
+    case 'radio':
+      return 'radio'
+    case 'range':
+      return 'slider'
+    case 'number':
+      return 'spinbutton'
+    case 'search':
+      return 'searchbox'
+    case 'hidden':
+      return 'none'
+    default:
+      return 'textbox'
+  }
+}
+
+function computeRole(el: Element): string {
+  const explicit = el.getAttribute('role')
+  if (explicit) return explicit.split(/\s+/)[0]
+
+  const tag = el.tagName.toLowerCase()
+  switch (tag) {
+    case 'a':
+    case 'area':
+      return el.hasAttribute('href') ? 'link' : 'generic'
+    case 'button':
+      return 'button'
+    case 'input':
+      return inputRole(el as HTMLInputElement)
+    case 'textarea':
+      return 'textbox'
+    case 'select':
+      return (el as HTMLSelectElement).multiple ? 'listbox' : 'combobox'
+    case 'option':
+      return 'option'
+    case 'img':
+      return 'img'
+    case 'h1':
+    case 'h2':
+    case 'h3':
+    case 'h4':
+    case 'h5':
+    case 'h6':
+      return 'heading'
+    case 'nav':
+      return 'navigation'
+    case 'main':
+      return 'main'
+    case 'header':
+      return 'banner'
+    case 'footer':
+      return 'contentinfo'
+    case 'aside':
+      return 'complementary'
+    case 'form':
+      return 'form'
+    case 'article':
+      return 'article'
+    case 'ul':
+    case 'ol':
+      return 'list'
+    case 'li':
+      return 'listitem'
+    case 'table':
+      return 'table'
+    case 'tr':
+      return 'row'
+    case 'td':
+      return 'cell'
+    case 'th':
+      return 'columnheader'
+    case 'p':
+      return 'paragraph'
+    case 'section':
+      return ariaName(el) ? 'region' : 'generic'
+    default:
+      return 'generic'
+  }
+}
+
+// Accessible name from aria-* attributes only.
+function ariaName(el: Element): string {
+  const ariaLabel = el.getAttribute('aria-label')
+  if (ariaLabel) return collapse(ariaLabel)
+
+  const labelledby = el.getAttribute('aria-labelledby')
+  if (labelledby) {
+    const parts: string[] = []
+    each(labelledby.split(/\s+/), (id: string) => {
+      const ref = document.getElementById(id)
+      if (ref) parts.push(ref.textContent || '')
+    })
+    const name = collapse(parts.join(' '))
+    if (name) return name
+  }
+
+  return ''
+}
+
+function labelText(el: HTMLElement): string {
+  const labels = (el as any).labels as NodeListOf<HTMLElement> | undefined
+  if (labels && labels.length) {
+    const parts: string[] = []
+    each(labels, (label: HTMLElement) => parts.push(label.textContent || ''))
+    return collapse(parts.join(' '))
+  }
+  return ''
+}
+
+function computeName(el: Element, role: string): string {
+  const aria = ariaName(el)
+  if (aria) return aria
+
+  const tag = el.tagName.toLowerCase()
+
+  if (tag === 'img' || tag === 'area') {
+    return collapse(el.getAttribute('alt') || '')
+  }
+  if (tag === 'input') {
+    const input = el as HTMLInputElement
+    if (role === 'button') {
+      return collapse(input.value || input.getAttribute('alt') || '')
+    }
+    return (
+      labelText(input) ||
+      collapse(
+        input.getAttribute('placeholder') || input.getAttribute('title') || '',
+      )
+    )
+  }
+  if (tag === 'textarea' || tag === 'select') {
+    return (
+      labelText(el as HTMLElement) ||
+      collapse(el.getAttribute('placeholder') || el.getAttribute('title') || '')
+    )
+  }
+
+  // For interactive / heading / option roles, the visible text is the name.
+  switch (role) {
+    case 'link':
+    case 'button':
+    case 'heading':
+    case 'option':
+    case 'menuitem':
+    case 'tab':
+    case 'columnheader':
+    case 'cell':
+      return collapse(el.textContent || '')
+    default:
+      return collapse(el.getAttribute('title') || '')
+  }
+}
+
+const FOCUSABLE_TAGS = ['a', 'button', 'input', 'select', 'textarea']
+
+function isFocusable(el: Element): boolean {
+  const tag = el.tagName.toLowerCase()
+  if (tag === 'a' || tag === 'area') return el.hasAttribute('href')
+  if (FOCUSABLE_TAGS.indexOf(tag) !== -1) {
+    return !(el as HTMLInputElement).disabled
+  }
+  if (el.hasAttribute('tabindex')) return true
+  if ((el as HTMLElement).isContentEditable) return true
+  return false
+}
+
+class Builder {
+  nodes: Accessibility.AXNode[] = []
+  private id = 0
+
+  private nextId(): string {
+    return `ax_${++this.id}`
+  }
+
+  build(): Accessibility.AXNode[] {
+    const root: Accessibility.AXNode = {
+      nodeId: this.nextId(),
+      ignored: false,
+      role: str('RootWebArea'),
+      name: str(document.title || ''),
+      childIds: [],
+      backendDOMNodeId: nodeManager.getOrCreateNodeId(document.documentElement),
+    }
+    this.nodes.push(root)
+    root.childIds = this.buildChildren(
+      document.body || document.documentElement,
+    )
+    return this.nodes
+  }
+
+  private buildChildren(parent: Node): string[] {
+    const childIds: string[] = []
+    const children = nodeManager.filterNodes((parent as any).childNodes)
+    each(children, (child: Node) => {
+      const id = this.buildNode(child)
+      if (id) childIds.push(id)
+    })
+    return childIds
+  }
+
+  private buildNode(node: Node): string | null {
+    if (node.nodeType === 3) {
+      const text = collapse(node.nodeValue || '')
+      if (!text) return null
+      const id = this.nextId()
+      this.nodes.push({
+        nodeId: id,
+        ignored: false,
+        role: str('StaticText'),
+        name: str(text),
+        backendDOMNodeId: nodeManager.getOrCreateNodeId(node),
+      })
+      return id
+    }
+
+    if (node.nodeType !== 1) return null
+    const el = node as Element
+    if (isHidden(el)) return null
+
+    const role = computeRole(el)
+    if (role === 'none' && !el.childNodes.length) return null
+
+    const id = this.nextId()
+    const payload: Accessibility.AXNode = {
+      nodeId: id,
+      ignored: false,
+      role: str(role),
+      name: str(computeName(el, role)),
+      properties: this.computeProperties(el, role),
+      backendDOMNodeId: nodeManager.getOrCreateNodeId(el),
+    }
+
+    const tag = el.tagName.toLowerCase()
+    if (tag === 'input' || tag === 'textarea' || tag === 'select') {
+      payload.value = str((el as HTMLInputElement).value || '')
+    }
+
+    // Leaf roles: do not expose internal children.
+    const isLeaf = tag === 'img' || role === 'textbox' || role === 'slider'
+    payload.childIds = isLeaf ? [] : this.buildChildren(el)
+
+    this.nodes.push(payload)
+    return id
+  }
+
+  private computeProperties(
+    el: Element,
+    role: string,
+  ): Accessibility.AXProperty[] {
+    const properties: Accessibility.AXProperty[] = []
+
+    if (isFocusable(el)) {
+      properties.push({ name: 'focusable', value: bool(true) })
+    }
+    if ((el as HTMLInputElement).disabled) {
+      properties.push({ name: 'disabled', value: bool(true) })
+    }
+    if (role === 'checkbox' || role === 'radio') {
+      properties.push({
+        name: 'checked',
+        value: str((el as HTMLInputElement).checked ? 'true' : 'false'),
+      })
+    }
+    if (role === 'heading') {
+      const level = parseInt(el.tagName.slice(1), 10)
+      if (level) {
+        properties.push({
+          name: 'level',
+          value: { type: 'integer' as Accessibility.AXValueType, value: level },
+        })
+      }
+    }
+
+    return properties
+  }
+}
+
+export function getFullAXTree(): Accessibility.GetFullAXTreeResponse {
+  return {
+    nodes: new Builder().build(),
+  }
+}
diff --git a/src/wdmcp/executionContext.ts b/src/wdmcp/executionContext.ts
new file mode 100644
index 0000000..c146a48
--- /dev/null
+++ b/src/wdmcp/executionContext.ts
@@ -0,0 +1,45 @@
+import connector from '../lib/connector'
+import { MAIN_FRAME_ID } from '../lib/constants'
+
+// chobitsu has a single real JS global, so "isolated worlds" are faked: every
+// context maps to the same global. puppeteer only needs each world to have a
+// distinct id and an `executionContextCreated` event carrying `auxData.frameId`
+// so it can bind the world to the main frame. evaluate/callFunctionOn ignore the
+// context id and run in the real global, which is fine for snapshots/locators.
+
+let nextId = 1
+
+const makeAuxData = (isDefault: boolean) => {
+  return {
+    isDefault,
+    type: isDefault ? 'default' : 'isolated',
+    frameId: MAIN_FRAME_ID,
+  }
+}
+
+/** The default (main world) execution context. Emitted on `Runtime.enable`. */
+export const mainContext = {
+  id: nextId++,
+  name: 'top',
+  origin: location.origin,
+  uniqueId: 'wdmcp-ctx-1',
+  auxData: makeAuxData(true),
+}
+
+/**
+ * Allocates a fake isolated world and announces it via
+ * `Runtime.executionContextCreated`. Returns the new execution context id.
+ */
+export const createContext = (name: string) => {
+  const id = nextId++
+  connector.trigger('Runtime.executionContextCreated', {
+    context: {
+      id,
+      name,
+      origin: location.origin,
+      uniqueId: `wdmcp-ctx-${id}`,
+      auxData: makeAuxData(false),
+    },
+  })
+  return id
+}
diff --git a/src/wdmcp/input.ts b/src/wdmcp/input.ts
new file mode 100644
index 0000000..adea6fe
--- /dev/null
+++ b/src/wdmcp/input.ts
@@ -0,0 +1,443 @@
+import Protocol from 'devtools-protocol'
+import Input = Protocol.Input
+
+interface Mods {
+  altKey: boolean
+  ctrlKey: boolean
+  metaKey: boolean
+  shiftKey: boolean
+}
+
+function decodeModifiers(m: number): Mods {
+  return {
+    altKey: !!(m & 1),
+    ctrlKey: !!(m & 2),
+    metaKey: !!(m & 4),
+    shiftKey: !!(m & 8),
+  }
+}
+
+function getTarget(): HTMLElement {
+  let el: Element | null = document.activeElement
+  while (el && el.shadowRoot && el.shadowRoot.activeElement) {
+    el = el.shadowRoot.activeElement
+  }
+  if (el instanceof HTMLElement) return el
+  return document.body
+}
+
+export function dispatchKeyEvent(params: Input.DispatchKeyEventRequest) {
+  const mods = decodeModifiers(params.modifiers || 0)
+  const target = getTarget()
+  const text = params.text || ''
+
+  if (params.type === 'char') {
+    if (text) insertIntoField(target, text)
+    return
+  }
+
+  const domType = params.type === 'keyUp' ? 'keyup' : 'keydown'
+  const ev = buildKeyboardEvent(domType, params, mods)
+  target.dispatchEvent(ev)
+
+  if (domType !== 'keydown' || ev.defaultPrevented) return
+  applyDefaultEditing(target, params, mods, text)
+}
+
+export function insertText(params: Input.InsertTextRequest) {
+  const text = params.text || ''
+  if (!text) return
+  insertIntoField(getTarget(), text)
+}
+
+function buildKeyboardEvent(
+  domType: 'keydown' | 'keyup',
+  params: Input.DispatchKeyEventRequest,
+  mods: Mods
+): KeyboardEvent {
+  const ev = new KeyboardEvent(domType, {
+    key: params.key || '',
+    code: params.code || '',
+    location: params.location || 0,
+    repeat: !!params.autoRepeat,
+    isComposing: false,
+    bubbles: true,
+    cancelable: true,
+    view: window,
+    altKey: mods.altKey,
+    ctrlKey: mods.ctrlKey,
+    metaKey: mods.metaKey,
+    shiftKey: mods.shiftKey,
+  })
+  const vk = params.windowsVirtualKeyCode || 0
+  defineLegacyProp(ev, 'keyCode', vk)
+  defineLegacyProp(ev, 'which', vk)
+  return ev
+}
+
+function defineLegacyProp(ev: KeyboardEvent, name: string, value: number) {
+  Object.defineProperty(ev, name, {
+    configurable: true,
+    get() {
+      return value
+    },
+  })
+}
+
+function applyDefaultEditing(
+  el: HTMLElement,
+  params: Input.DispatchKeyEventRequest,
+  mods: Mods,
+  text: string
+) {
+  const key = params.key || ''
+
+  if (
+    (mods.ctrlKey || mods.metaKey) &&
+    (key === 'a' || key === 'A' || params.code === 'KeyA')
+  ) {
+    selectAll(el)
+    return
+  }
+  if (mods.ctrlKey || mods.metaKey || mods.altKey) return
+
+  if (text && text !== '\r') {
+    insertIntoField(el, text)
+    return
+  }
+  if (key === 'Enter' || text === '\r') {
+    insertNewline(el)
+    return
+  }
+
+  switch (key) {
+    case 'Backspace':
+      handleBackspaceDelete(el, false)
+      break
+    case 'Delete':
+      handleBackspaceDelete(el, true)
+      break
+    case 'ArrowLeft':
+      handleArrow(el, -1, mods.shiftKey)
+      break
+    case 'ArrowRight':
+      handleArrow(el, 1, mods.shiftKey)
+      break
+    case 'Home':
+      handleHomeEnd(el, false, mods.shiftKey)
+      break
+    case 'End':
+      handleHomeEnd(el, true, mods.shiftKey)
+      break
+  }
+}
+
+/* ------------------------------- field model ------------------------------ */
+
+type TextInput = HTMLInputElement | HTMLTextAreaElement
+
+function isTextInput(el: HTMLElement): el is TextInput {
+  return el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement
+}
+
+const SELECTABLE_INPUT_TYPES = ['text', 'search', 'url', 'tel', 'password']
+
+function supportsSelection(el: TextInput): boolean {
+  if (el instanceof HTMLTextAreaElement) return true
+  return SELECTABLE_INPUT_TYPES.indexOf(el.type) >= 0
+}
+
+function numOr(v: number | null, fallback: number): number {
+  return v === null ? fallback : v
+}
+
+function clamp(v: number, lo: number, hi: number): number {
+  return Math.max(lo, Math.min(hi, v))
+}
+
+function setSelection(
+  el: TextInput,
+  start: number,
+  end: number,
+  direction?: 'forward' | 'backward' | 'none'
+) {
+  try {
+    el.setSelectionRange(start, end, direction)
+  } catch (e) {
+    /* selection unsupported for this input type */
+  }
+}
+
+function setNativeValue(el: TextInput, value: string) {
+  const proto =
+    el instanceof HTMLTextAreaElement
+      ? HTMLTextAreaElement.prototype
+      : HTMLInputElement.prototype
+  const desc = Object.getOwnPropertyDescriptor(proto, 'value')
+  if (desc && desc.set) {
+    desc.set.call(el, value)
+  } else {
+    el.value = value
+  }
+}
+
+function dispatchBeforeInput(
+  el: HTMLElement,
+  inputType: string,
+  data: string | null
+): boolean {
+  return el.dispatchEvent(
+    new InputEvent('beforeinput', {
+      bubbles: true,
+      cancelable: true,
+      inputType,
+      data,
+    })
+  )
+}
+
+function dispatchInput(el: HTMLElement, inputType: string, data: string | null) {
+  el.dispatchEvent(
+    new InputEvent('input', {
+      bubbles: true,
+      cancelable: false,
+      inputType,
+      data,
+    })
+  )
+}
+
+/* --------------------------------- insert --------------------------------- */
+
+function insertIntoField(el: HTMLElement, text: string) {
+  if (isTextInput(el)) {
+    replaceSelection(el, text, 'insertText', text)
+  } else if (el.isContentEditable) {
+    insertIntoContentEditable(el, text)
+  }
+}
+
+function replaceSelection(
+  el: TextInput,
+  text: string,
+  inputType: string,
+  data: string | null
+) {
+  if (!dispatchBeforeInput(el, inputType, data)) return
+
+  if (supportsSelection(el)) {
+    const value = el.value
+    const len = value.length
+    const start = numOr(el.selectionStart, len)
+    const end = numOr(el.selectionEnd, len)
+    setNativeValue(el, value.slice(0, start) + text + value.slice(end))
+    const caret = start + text.length
+    setSelection(el, caret, caret)
+  } else {
+    setNativeValue(el, el.value + text)
+  }
+
+  dispatchInput(el, inputType, data)
+}
+
+function insertNewline(el: HTMLElement) {
+  if (el instanceof HTMLTextAreaElement) {
+    replaceSelection(el, '\n', 'insertLineBreak', null)
+  } else if (el.isContentEditable) {
+    insertParagraphInContentEditable(el)
+  }
+}
+
+/* --------------------------------- delete --------------------------------- */
+
+function handleBackspaceDelete(el: HTMLElement, forward: boolean) {
+  if (isTextInput(el)) {
+    deleteInInput(el, forward)
+  } else if (el.isContentEditable) {
+    deleteInContentEditable(el, forward)
+  }
+}
+
+function deleteInInput(el: TextInput, forward: boolean) {
+  const inputType = forward ? 'deleteContentForward' : 'deleteContentBackward'
+
+  if (!supportsSelection(el)) {
+    if (!forward && el.value.length) {
+      if (!dispatchBeforeInput(el, inputType, null)) return
+      setNativeValue(el, el.value.slice(0, -1))
+      dispatchInput(el, inputType, null)
+    }
+    return
+  }
+
+  const value = el.value
+  const len = value.length
+  let start = numOr(el.selectionStart, len)
+  let end = numOr(el.selectionEnd, len)
+
+  if (start === end) {
+    if (forward) {
+      if (end >= len) return
+      end += 1
+    } else {
+      if (start <= 0) return
+      start -= 1
+    }
+  }
+
+  if (!dispatchBeforeInput(el, inputType, null)) return
+  setNativeValue(el, value.slice(0, start) + value.slice(end))
+  setSelection(el, start, start)
+  dispatchInput(el, inputType, null)
+}
+
+/* ---------------------------- caret movement ------------------------------ */
+
+function handleArrow(el: HTMLElement, delta: number, extend: boolean) {
+  if (isTextInput(el)) {
+    moveCaretInInput(el, delta, extend)
+  } else if (el.isContentEditable) {
+    ceModify(extend, delta < 0 ? 'backward' : 'forward', 'character')
+  }
+}
+
+function handleHomeEnd(el: HTMLElement, toEnd: boolean, extend: boolean) {
+  if (isTextInput(el)) {
+    moveCaretToEdgeInInput(el, toEnd, extend)
+  } else if (el.isContentEditable) {
+    ceModify(extend, toEnd ? 'forward' : 'backward', 'lineboundary')
+  }
+}
+
+function moveCaretInInput(el: TextInput, delta: number, extend: boolean) {
+  if (!supportsSelection(el)) return
+  const len = el.value.length
+  const start = numOr(el.selectionStart, 0)
+  const end = numOr(el.selectionEnd, 0)
+
+  if (!extend) {
+    let pos: number
+    if (start !== end) pos = delta < 0 ? start : end
+    else pos = clamp(start + delta, 0, len)
+    setSelection(el, pos, pos)
+    return
+  }
+
+  const backward = el.selectionDirection === 'backward'
+  const anchor = backward ? end : start
+  const focus = clamp((backward ? start : end) + delta, 0, len)
+  setSelection(
+    el,
+    Math.min(anchor, focus),
+    Math.max(anchor, focus),
+    focus < anchor ? 'backward' : 'forward'
+  )
+}
+
+function moveCaretToEdgeInInput(el: TextInput, toEnd: boolean, extend: boolean) {
+  if (!supportsSelection(el)) return
+  const target = toEnd ? el.value.length : 0
+
+  if (!extend) {
+    setSelection(el, target, target)
+    return
+  }
+
+  const backward = el.selectionDirection === 'backward'
+  const start = numOr(el.selectionStart, 0)
+  const end = numOr(el.selectionEnd, 0)
+  const anchor = backward ? end : start
+  setSelection(
+    el,
+    Math.min(anchor, target),
+    Math.max(anchor, target),
+    target < anchor ? 'backward' : 'forward'
+  )
+}
+
+/* -------------------------------- select all ------------------------------ */
+
+function selectAll(el: HTMLElement) {
+  if (isTextInput(el)) {
+    if (supportsSelection(el)) setSelection(el, 0, el.value.length)
+    return
+  }
+  if (el.isContentEditable) {
+    const sel = window.getSelection()
+    if (!sel) return
+    const range = document.createRange()
+    range.selectNodeContents(el)
+    sel.removeAllRanges()
+    sel.addRange(range)
+  }
+}
+
+/* ----------------------------- contenteditable ---------------------------- */
+
+function insertIntoContentEditable(el: HTMLElement, text: string) {
+  const sel = window.getSelection()
+  if (sel && sel.rangeCount > 0) {
+    if (!dispatchBeforeInput(el, 'insertText', text)) return
+    const range = sel.getRangeAt(0)
+    range.deleteContents()
+    const node = document.createTextNode(text)
+    range.insertNode(node)
+    range.setStartAfter(node)
+    range.collapse(true)
+    sel.removeAllRanges()
+    sel.addRange(range)
+    dispatchInput(el, 'insertText', text)
+    return
+  }
+  try {
+    document.execCommand('insertText', false, text)
+  } catch (e) {
+    /* execCommand unavailable */
+  }
+}
+
+function deleteInContentEditable(el: HTMLElement, forward: boolean) {
+  const inputType = forward ? 'deleteContentForward' : 'deleteContentBackward'
+  const sel = window.getSelection()
+  if (!sel || sel.rangeCount === 0) return
+  if (!dispatchBeforeInput(el, inputType, null)) return
+
+  if (sel.getRangeAt(0).collapsed) {
+    ceModify(true, forward ? 'forward' : 'backward', 'character')
+  }
+  const range = sel.getRangeAt(0)
+  range.deleteContents()
+  range.collapse(true)
+  sel.removeAllRanges()
+  sel.addRange(range)
+  dispatchInput(el, inputType, null)
+}
+
+function insertParagraphInContentEditable(el: HTMLElement) {
+  const sel = window.getSelection()
+  if (!sel || sel.rangeCount === 0) return
+  if (!dispatchBeforeInput(el, 'insertParagraph', null)) return
+  const range = sel.getRangeAt(0)
+  range.deleteContents()
+  const br = document.createElement('br')
+  range.insertNode(br)
+  range.setStartAfter(br)
+  range.collapse(true)
+  sel.removeAllRanges()
+  sel.addRange(range)
+  dispatchInput(el, 'insertParagraph', null)
+}
+
+function ceModify(
+  extend: boolean,
+  direction: 'forward' | 'backward',
+  granularity: string
+) {
+  const sel = window.getSelection()
+  if (!sel || typeof sel.modify !== 'function') return
+  try {
+    sel.modify(extend ? 'extend' : 'move', direction, granularity)
+  } catch (e) {
+    /* modify unsupported */
+  }
+}
diff --git a/src/wdmcp/page.ts b/src/wdmcp/page.ts
new file mode 100644
index 0000000..47ba2fd
--- /dev/null
+++ b/src/wdmcp/page.ts
@@ -0,0 +1,285 @@
+import Protocol from 'devtools-protocol'
+import Page = Protocol.Page
+
+export const cropCanvas = (
+  source: HTMLCanvasElement,
+  region: Page.Viewport,
+): HTMLCanvasElement => {
+  const scale = region.scale || 1
+  const canvas = document.createElement('canvas')
+  canvas.width = Math.max(1, Math.round(region.width * scale))
+  canvas.height = Math.max(1, Math.round(region.height * scale))
+  const ctx = canvas.getContext('2d')
+  if (ctx) {
+    ctx.drawImage(
+      source,
+      region.x,
+      region.y,
+      region.width,
+      region.height,
+      0,
+      0,
+      canvas.width,
+      canvas.height,
+    )
+  }
+  return canvas
+}
+
+type HistoryEntry = Page.NavigationEntry
+
+type HistorySnapshot = {
+  currentIndex: number
+  entries: HistoryEntry[]
+}
+
+const STORAGE_KEY = '__WDMCP_HISTORY'
+let installed = false
+let nextEntryId = 1
+let currentEntryId = 0
+let entries: HistoryEntry[] = []
+let onSameDocumentNavigation: ((url: string) => void) | undefined
+let originalPushState: History['pushState'] | undefined
+let originalReplaceState: History['replaceState'] | undefined
+let pendingEntryId: number | undefined
+
+export function installNavigationHistoryShim(
+  onNavigation: (url: string) => void,
+) {
+  onSameDocumentNavigation = onNavigation
+  ensureHistoryState()
+
+  if (installed) {
+    return
+  }
+
+  installed = true
+  originalPushState = history.pushState
+  originalReplaceState = history.replaceState
+
+  history.pushState = function (state, unused, url) {
+    originalPushState!.call(this, state, unused, url)
+    pushCurrentEntry('link')
+    notifySameDocumentNavigation()
+  }
+
+  history.replaceState = function (state, unused, url) {
+    originalReplaceState!.call(this, state, unused, url)
+    replaceCurrentEntry()
+    notifySameDocumentNavigation()
+  }
+
+  addEventListener('popstate', () => {
+    if (pendingEntryId !== undefined) {
+      currentEntryId = pendingEntryId
+      pendingEntryId = undefined
+    } else {
+      currentEntryId = findEntryForCurrentUrl(currentEntryId)
+    }
+    replaceCurrentEntry()
+    notifySameDocumentNavigation()
+  })
+
+  addEventListener('hashchange', () => {
+    if (pendingEntryId !== undefined) {
+      return
+    }
+    pushCurrentEntry('link')
+    notifySameDocumentNavigation()
+  })
+}
+
+export function getNavigationHistorySnapshot(): HistorySnapshot {
+  ensureHistoryState()
+  return {
+    currentIndex: getCurrentIndex(),
+    entries: entries.slice(),
+  }
+}
+
+export function navigateToHistoryEntry(entryId: number) {
+  ensureHistoryState()
+  const currentIndex = getCurrentIndex()
+  const targetIndex = entries.findIndex(entry => entry.id === entryId)
+
+  if (targetIndex === -1) {
+    throw new Error(`Navigation history entry not found: ${entryId}`)
+  }
+
+  const delta = targetIndex - currentIndex
+  if (delta === 0) {
+    return
+  }
+
+  pendingEntryId = entryId
+  history.go(delta)
+}
+
+function ensureHistoryState() {
+  loadStoredHistory()
+
+  if (!entries.length) {
+    entries = [createEntry(0, 'typed')]
+    currentEntryId = 0
+    nextEntryId = 1
+    storeHistory()
+    return
+  }
+
+  const currentIndex = entries.findIndex(entry => entry.id === currentEntryId)
+  if (currentIndex === -1) {
+    currentEntryId = entries[entries.length - 1].id
+  }
+
+  const matchingIndex = findBestCurrentUrlIndex()
+  if (matchingIndex === -1) {
+    pushCurrentEntry('link')
+  } else {
+    currentEntryId = entries[matchingIndex].id
+    replaceCurrentEntry()
+  }
+}
+
+function pushCurrentEntry(transitionType: Page.TransitionType) {
+  const currentIndex = getCurrentIndex()
+  entries = entries.slice(0, currentIndex + 1)
+  currentEntryId = nextEntryId++
+  entries.push(createEntry(currentEntryId, transitionType))
+  storeHistory()
+}
+
+function replaceCurrentEntry() {
+  const currentIndex = getCurrentIndex()
+  entries[currentIndex] = {
+    ...entries[currentIndex],
+    url: location.href,
+    userTypedURL: location.href,
+    title: document.title,
+  }
+  storeHistory()
+}
+
+function createEntry(
+  id: number,
+  transitionType: Page.TransitionType,
+): HistoryEntry {
+  return {
+    id,
+    url: location.href,
+    userTypedURL: location.href,
+    title: document.title,
+    transitionType,
+  }
+}
+
+function getCurrentIndex() {
+  const index = entries.findIndex(entry => entry.id === currentEntryId)
+  if (index !== -1) {
+    return index
+  }
+
+  currentEntryId = entries.length ? entries[entries.length - 1].id : 0
+  return entries.length ? entries.length - 1 : 0
+}
+
+function findEntryForCurrentUrl(fallbackEntryId: number) {
+  const currentIndex = getCurrentIndex()
+
+  if (entries[currentIndex] && entries[currentIndex].url === location.href) {
+    return entries[currentIndex].id
+  }
+
+  const beforeIndex = entries
+    .slice(0, currentIndex)
+    .map((entry, index) => ({ entry, index }))
+    .reverse()
+    .find(item => item.entry.url === location.href)
+  if (beforeIndex) {
+    return beforeIndex.entry.id
+  }
+
+  const afterIndex = entries
+    .slice(currentIndex + 1)
+    .find(entry => entry.url === location.href)
+  if (afterIndex) {
+    return afterIndex.id
+  }
+
+  return fallbackEntryId
+}
+
+function findBestCurrentUrlIndex() {
+  const currentIndex = entries.findIndex(entry => entry.id === currentEntryId)
+  if (currentIndex !== -1 && entries[currentIndex].url === location.href) {
+    return currentIndex
+  }
+
+  return entries.findIndex(entry => entry.url === location.href)
+}
+
+function notifySameDocumentNavigation() {
+  if (onSameDocumentNavigation) {
+    onSameDocumentNavigation(location.href)
+  }
+}
+
+function loadStoredHistory() {
+  const stored = readStoredHistory()
+  if (!stored) {
+    return
+  }
+
+  entries = stored.entries
+  currentEntryId = stored.currentEntryId
+  nextEntryId = Math.max(stored.nextEntryId, ...entries.map(entry => entry.id + 1))
+}
+
+function readStoredHistory():
+  | { entries: HistoryEntry[]; currentEntryId: number; nextEntryId: number }
+  | undefined {
+  try {
+    const raw = sessionStorage.getItem(STORAGE_KEY)
+    if (!raw) {
+      return
+    }
+
+    const parsed = JSON.parse(raw)
+    if (
+      !Array.isArray(parsed.entries) ||
+      typeof parsed.currentEntryId !== 'number' ||
+      typeof parsed.nextEntryId !== 'number'
+    ) {
+      return
+    }
+
+    return {
+      entries: parsed.entries.filter(isHistoryEntry),
+      currentEntryId: parsed.currentEntryId,
+      nextEntryId: parsed.nextEntryId,
+    }
+  } catch {
+    return
+  }
+}
+
+function storeHistory() {
+  try {
+    sessionStorage.setItem(
+      STORAGE_KEY,
+      JSON.stringify({ entries, currentEntryId, nextEntryId }),
+    )
+  } catch {
+    // Keep the in-memory copy when sessionStorage is unavailable.
+  }
+}
+
+function isHistoryEntry(value: any): value is HistoryEntry {
+  return (
+    value &&
+    typeof value.id === 'number' &&
+    typeof value.url === 'string' &&
+    typeof value.userTypedURL === 'string' &&
+    typeof value.title === 'string' &&
+    typeof value.transitionType === 'string'
+  )
+}
