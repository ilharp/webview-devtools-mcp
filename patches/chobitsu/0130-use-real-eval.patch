+function wrapByValue(value: any): any {
+  const type = typeof value
+
+  if (type === 'bigint') {
+    return { type, unserializableValue: `${value}n` }
+  }
+  if (type === 'number') {
+    if (isNaN(value)) return { type, unserializableValue: 'NaN' }
