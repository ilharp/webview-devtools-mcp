+++ b/src/lib/executionContext.ts
@@ -0,0 +1,45 @@
+import connector from './connector'
+import { MAIN_FRAME_ID } from './constants'
+
+// chobitsu has a single real JS global, so "isolated worlds" are faked: every
+// context maps to the same global. puppeteer only needs each world to have a
+// distinct id and an `executionContextCreated` event carrying `auxData.frameId`
+// so it can bind the world to the main frame. evaluate/callFunctionOn ignore the
+// context id and run in the real global, which is fine for snapshots/locators.
+
+let nextId = 1
+
+function makeAuxData(isDefault: boolean) {
+  return {
+    isDefault,
+    type: isDefault ? 'default' : 'isolated',
+    frameId: MAIN_FRAME_ID,
+  }
+}
+
+/** The default (main world) execution context. Emitted on `Runtime.enable`. */
+export const mainContext = {
+  id: nextId++,
+  name: 'top',
+  origin: location.origin,
+  uniqueId: 'wdmcp-ctx-1',
+  auxData: makeAuxData(true),
+}
+
+/**
+ * Allocates a fake isolated world and announces it via
+ * `Runtime.executionContextCreated`. Returns the new execution context id.
+ */
+export function createContext(name: string) {
+  const id = nextId++
+  connector.trigger('Runtime.executionContextCreated', {
+    context: {
+      id,
+      name,
+      origin: location.origin,
+      uniqueId: `wdmcp-ctx-${id}`,
+      auxData: makeAuxData(false),
+    },
+  })
+  return id
+}
