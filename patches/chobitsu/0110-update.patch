+// puppeteer's FrameManager.initialize() needs the frame tree to build its frame
+// model. chobitsu is single-frame, so report just the main frame.
+export function getFrameTree() {
+  return {
+    frameTree: {
+      frame: {
+        id: MAIN_FRAME_ID,
+        loaderId: MAIN_LOADER_ID,
+        url: getUrl(),
+        domainAndRegistry: '',
+        securityOrigin: getOrigin(),
+        mimeType: 'text/html',
+        secureContextType: 'Secure',
+        crossOriginIsolatedContextType: 'NotIsolated',
+        gatedAPIFeatures: [],
+      },
+    },
+  }
+}
+
+// Lifecycle events aren't modeled yet; ack so page creation doesn't fail.
+export function setLifecycleEventsEnabled() {}
+
+let scriptIdSeq = 0
+
+// puppeteer registers a utility-world preload script before creating the
+// isolated world. chobitsu doesn't re-inject on navigation, but the call must
+// return an identifier so the isolated-world setup proceeds.
+export function addScriptToEvaluateOnNewDocument() {
+  return { identifier: `${++scriptIdSeq}` }
+}
+
+export function removeScriptToEvaluateOnNewDocument() {}
+
+export function createIsolatedWorld(
+  params: Page.CreateIsolatedWorldRequest
+): Page.CreateIsolatedWorldResponse {
+  const executionContextId = createContext(params.worldName || '')
+  return { executionContextId }
+}
+
 export function reload() {
   location.reload()
 }
