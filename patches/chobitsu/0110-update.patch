@@ -242,3 +284,81 @@ async function captureScreenshot() {
 
   isCapturingScreenshot = false
 }
+
+// puppeteer's page.screenshot() issues Page.captureScreenshot. chobitsu has no
+// real surface capture, so render the DOM with html2canvas (the same approach
+// the screencast above uses) and honour the requested format/quality/clip.
+// Registered as the `captureScreenshot` method in index.ts to avoid colliding
+// with the private screencast helper of the same name.
+export async function capturePageScreenshot(
+  params: Page.CaptureScreenshotRequest
+): Promise<Page.CaptureScreenshotResponse> {
+  const { format = 'png', quality, clip, captureBeyondViewport } = params
+
+  const options: Partial<html2canvasOptions> = {
+    imageTimeout: 5000,
+    scale: 1,
+    logging: false,
+    ignoreElements(node) {
+      return !isValidNode(node)
+    },
+  }
+  if (proxy) {
+    options.proxy = proxy
+  } else {
+    options.foreignObjectRendering = true
+    options.useCORS = true
+  }
+
+  const canvas = await html2canvas(document.body, options)
+
+  // html2canvas renders the whole body at 1 canvas px per CSS px, in document
+  // coordinates. A CDP clip is already in those coordinates, so use it as-is.
+  // Without a clip, captureBeyondViewport (puppeteer's fullPage path) means
+  // "the whole page"; otherwise only the visible viewport is expected.
+  const region: Page.Viewport = clip || {
+    x: captureBeyondViewport ? 0 : window.scrollX,
+    y: captureBeyondViewport ? 0 : window.scrollY,
+    width: captureBeyondViewport ? canvas.width : window.innerWidth,
+    height: captureBeyondViewport ? canvas.height : window.innerHeight,
+    scale: 1,
+  }
+
+  const mimeType =
+    format === 'jpeg'
+      ? 'image/jpeg'
+      : format === 'webp'
+        ? 'image/webp'
+        : 'image/png'
+
+  const data = cropCanvas(canvas, region)
+    .toDataURL(mimeType, quality === undefined ? undefined : quality / 100)
+    .replace(/^data:image\/\w+;base64,/, '')
+
+  return { data }
+}
+
+function cropCanvas(
+  source: HTMLCanvasElement,
+  region: Page.Viewport
+): HTMLCanvasElement {
+  const scale = region.scale || 1
+  const canvas = document.createElement('canvas')
+  canvas.width = Math.max(1, Math.round(region.width * scale))
+  canvas.height = Math.max(1, Math.round(region.height * scale))
+  const ctx = canvas.getContext('2d')
+  if (ctx) {
+    ctx.drawImage(
+      source,
+      region.x,
+      region.y,
+      region.width,
+      region.height,
+      0,
+      0,
+      canvas.width,
+      canvas.height
+    )
+  }
+  return canvas
+}
