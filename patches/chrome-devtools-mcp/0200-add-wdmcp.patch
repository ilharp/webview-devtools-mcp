+/* eslint-disable @local/check-license */
+
+import {EventEmitter} from 'node:events';
+
+import type {ConnectionTransport} from 'puppeteer';
+import type {WebSocket} from 'ws';
+
+import type {parseArguments} from './bin/chrome-devtools-mcp-cli-options.js';
+import {logger} from './logger.js';
+import type {ChiiCtx, ChiiTarget} from './third_party/index.js';
+import {chii} from './third_party/index.js';
+
+const {start} = chii;
+
+const CHII_CLIENT_PREFIX = 'wdmcp_client_';
+const SESSION_PREFIX = 'wdmcp_sess_';
+
+/**
+ * A virtual websocket bridging this transport and a single chii client.
+ *
+ * chii drives it just like a real `ws`: it subscribes to `message`/`close`
+ * and calls `send` to deliver messages coming back from the target.
+ */
+interface ChiiClientWs extends EventEmitter {
+  /** Called by chii with messages coming from the target. */
+  send(message: string): void;
+
+  /** Tears down the underlying chii client channel. */
+  close(): void;
+}
+
+/** Minimal CDP message envelope (flat / "flatten" session mode). */
+interface CdpMessage {
+  id?: number;
+  method?: string;
+  params?: Record<string, unknown>;
+  result?: unknown;
+  error?: {code?: number; message: string};
+  sessionId?: string;
+}
+
+/** The subset of `Target.TargetInfo` puppeteer reads. */
+interface TargetInfo {
+  targetId: string;
+  type: 'page';
+  title: string;
+  url: string;
+  attached: boolean;
+  canAccessOpener: boolean;
+}
+
+export class WebviewDevtoolsMcpTransport implements ConnectionTransport {
+  constructor(
+    /**
+     * Send a message to chii client. Called by pptr.
+     */
+    private onPptrToChiiMessage: (message: string) => void,
+    /**
+     * Called by pptr.
+     */
+    private onPptrToChiiClose: () => void,
+  ) {}
+
+  /**
+   * Send a message to chii client. Called by pptr.
+   */
+  send = (message: string): void => {
+    logger?.(`[wdmcp] [->chii] ${message}`);
+    this.onPptrToChiiMessage(message);
+  };
+
+  /**
+   * Called by pptr.
+   */
+  close = (): void => {
+    logger?.(`[wdmcp] [->chii] close`);
+    this.onPptrToChiiClose();
+  };
+
+  /**
+   * Called by chii.
+   */
+  onmessage?: ((message: string) => void) | undefined;
+
+  /**
+   * Called by chii.
+   */
+  onclose?: (() => void) | undefined;
+
+  sendMessageToPptr = (message: string) => {
+    logger?.(`[wdmcp] [->pptr] ${message}`);
+    this.onmessage?.(message);
+  };
+
+  closePptr = () => {
+    logger?.(`[wdmcp] [->pptr] close`);
+    this.onclose?.();
+  };
+}
+
+/**
+ * CDP multiplexer / virtual browser endpoint.
+ *
+ * puppeteer's `ConnectionTransport` contract assumes the transport is already
+ * wired to a single, live, browser-level CDP endpoint. Here the real backends
+ * (webviews running chobitsu) connect later, asynchronously, 0..N of them, and
+ * come and go over time. A single chobitsu is a flat, page-level session: it has
+ * no `Browser` domain, only stub `Target` methods, and no `sessionId` concept.
+ *
+ * This class bridges that gap. It answers the browser/`Target` handshake itself
+ * (so `puppeteer.connect()` resolves immediately, even with zero webviews),
+ * presents every chii target as an independent CDP page target, and forwards
+ * page-level traffic to the right chobitsu by stamping/stripping `sessionId`.
+ * Webview connect/reload/disconnect become standard
+ * `Target.targetCreated`/`attachedToTarget`/`targetDestroyed` events, so
+ * puppeteer never sees a stale session.
+ */
+export class WebviewDevtoolsMcpContext {
+  /** Live chii targets, keyed by chii target id (== our CDP targetId). */
+  #targets = new Map<
+    string,
+    {clientId: string; emitter: ChiiClientWs; target: ChiiTarget}
+  >();
+
+  /** puppeteer sessionId -> chii targetId. */
+  #sessionToTarget = new Map<string, string>();
+
+  /** chii targetId -> set of puppeteer sessionIds attached to it. */
+  #targetSessions = new Map<string, Set<string>>();
+
+  /**
+   * In-flight forwarded request id -> originating sessionId. Lets us route a
+   * flat chobitsu response (which carries only `id`) back to the right session.
+   * Safe because puppeteer's id generator is shared across sessions, so ids are
+   * globally unique on this connection.
+   */
+  #pendingId = new Map<number, string>();
+
+  /** Set once puppeteer enables target discovery (`Target.setDiscoverTargets`). */
+  #discovering = false;
+
+  /**
+   * Set once puppeteer enables auto-attach (`Target.setAutoAttach`). puppeteer's
+   * ChromeTargetManager discovers pages exclusively through auto-attach, so
+   * until this is on we must not announce attachments.
+   */
+  #autoAttaching = false;
+
+  #sessionSeq = 0;
+
+  /** Resolvers waiting for the first webview to connect. */
+  #firstTargetWaiters: Array<() => void> = [];
+
+  transport = new WebviewDevtoolsMcpTransport(
+    (message: string) => {
+      this.#onPptrMessage(message);
+    },
+    () => {
+      this.#onPptrToChiiClose();
+    },
+  );
+
+  constructor(
+    private chiiCtx: ChiiCtx,
+    private serverArgs: ReturnType<typeof parseArguments>,
+  ) {
+    chiiCtx.wss.channelManager.on('target_changed', this.#onTargetChanged);
+    // Pick up any targets that connected before we subscribed.
+    this.#onTargetChanged();
+  }
+
+  static create = async ({
+    serverArgs,
+  }: {
+    serverArgs: ReturnType<typeof parseArguments>;
+  }) => {
+    const chiiCtx = start({
+      port: serverArgs.port,
+      host: serverArgs.host,
+      log: (...args) => {
+        logger?.(...args);
+      },
+    });
+
+    return new WebviewDevtoolsMcpContext(chiiCtx, serverArgs);
+  };
+
+  /**
+   * Resolves once at least one webview is connected. Used to make the first
+   * tool call wait for a target instead of failing with "No page selected".
+   */
+  whenFirstTargetReady = (timeoutMs: number): Promise<void> => {
+    if (this.#targets.size > 0) {
+      return Promise.resolve();
+    }
+    return new Promise<void>((resolve, reject) => {
+      let done = false;
+      const onReady = () => {
+        if (done) {
+          return;
+        }
+        done = true;
+        clearTimeout(timer);
+        resolve();
+      };
+      const timer = setTimeout(() => {
+        if (done) {
+          return;
+        }
+        done = true;
+        const i = this.#firstTargetWaiters.indexOf(onReady);
+        if (i >= 0) {
+          this.#firstTargetWaiters.splice(i, 1);
+        }
+        reject(
+          new Error(
+            `No webview connected to ${this.serverArgs.host}:${this.serverArgs.port} within ${timeoutMs}ms. Open your webview (inject target.js) and retry.`,
+          ),
+        );
+      }, timeoutMs);
+      this.#firstTargetWaiters.push(onReady);
+    });
+  };
+
+  // #region chii target lifecycle
+
+  #onTargetChanged = () => {
+    const targets = this.chiiCtx.wss.channelManager.getTargets() as Record<
+      string,
+      ChiiTarget
+    >;
+
+    // Additions and identity changes (same id, new connection == reload).
+    for (const targetId of Object.keys(targets)) {
+      const target = targets[targetId];
+      const existing = this.#targets.get(targetId);
+      if (existing) {
+        if (existing.target === target) {
+          continue;
+        }
+        // Same id, different chii target object: the webview reconnected
+        // (e.g. reload). Tear the old one down before recreating so puppeteer
+        // sees a clean destroy + create rather than a silently-swapped backend.
+        this.#destroyTarget(targetId);
+      }
+
+      const clientId = `${CHII_CLIENT_PREFIX}${targetId}`;
+      const emitter = new EventEmitter() as ChiiClientWs;
+
+      // chii owns this client's lifecycle: when the target ws closes it calls
+      // `close` (via the listener createClient puts on target.ws), which emits
+      // `close` so chii destroys the channel and drops the client.
+      emitter.close = () => {
+        emitter.emit('close');
+      };
+
+      // chii delivers this target's messages here.
+      emitter.send = (message: string) => {
+        this.#onChiiToPptr(targetId, message);
+      };
+
+      this.chiiCtx.wss.channelManager.createClient(
+        clientId,
+        emitter as unknown as WebSocket,
+        targetId,
+      );
+
+      this.#targets.set(targetId, {clientId, emitter, target});
+
+      if (this.#discovering) {
+        this.#emitTargetCreated(targetId, target, false);
+      }
+      if (this.#autoAttaching) {
+        this.#autoAttach(targetId);
+      }
+    }
+
+    // Removals.
+    for (const targetId of [...this.#targets.keys()]) {
+      if (targets[targetId]) {
+        continue;
+      }
+      this.#destroyTarget(targetId);
+    }
+
+    if (this.#targets.size > 0) {
+      this.#flushFirstTargetWaiters();
+    }
+  };
+
+  #destroyTarget = (targetId: string) => {
+    const entry = this.#targets.get(targetId);
+
+    // Detach every session attached to this target.
+    const sessions = this.#targetSessions.get(targetId);
+    if (sessions) {
+      for (const sessionId of [...sessions]) {
+        this.#dropSession(sessionId);
+      }
+    }
+
+    this.#targets.delete(targetId);
+
+    // Tear down the chii client channel.
+    entry?.emitter.close();
+
+    if (this.#discovering) {
+      this.#sendToPptr({method: 'Target.targetDestroyed', params: {targetId}});
+    }
+  };
+
+  // #endregion
+
+  // #region chobitsu -> puppeteer
+
+  #onChiiToPptr = (targetId: string, raw: string) => {
+    let msg: CdpMessage;
+    try {
+      msg = JSON.parse(raw) as CdpMessage;
+    } catch {
+      return;
+    }
+
+    if (msg.id !== undefined) {
+      // Response to a request we forwarded. Route back to its session.
+      const sessionId = this.#pendingId.get(msg.id);
+      if (sessionId === undefined) {
+        return;
+      }
+      this.#pendingId.delete(msg.id);
+      this.#sendToPptr({...msg, sessionId});
+      return;
+    }
+
+    // Unsolicited event. Deliver to every session attached to this target;
+    // puppeteer's per-session `frame.client !== session` guards dedupe it.
+    const sessions = this.#targetSessions.get(targetId);
+    if (!sessions) {
+      return;
+    }
+    for (const sessionId of sessions) {
+      this.#sendToPptr({...msg, sessionId});
+    }
+  };
+
+  // #endregion
+
+  // #region puppeteer -> multiplexer
+
+  #onPptrMessage = (raw: string) => {
+    let msg: CdpMessage;
+    try {
+      msg = JSON.parse(raw) as CdpMessage;
+    } catch {
+      return;
+    }
+
+    if (msg.sessionId) {
+      this.#handleSessionMessage(msg);
+    } else {
+      this.#handleConnectionMessage(msg);
+    }
+  };
+
+  #handleSessionMessage = (msg: CdpMessage) => {
+    const sessionId = msg.sessionId!;
+    const targetId = this.#sessionToTarget.get(sessionId);
+    if (!targetId) {
+      this.#replyError(msg.id, -32001, 'Session not found', sessionId);
+      return;
+    }
+
+    // We own the Target domain entirely (chobitsu only stubs it).
+    if (msg.method?.startsWith('Target.')) {
+      if (msg.id !== undefined) {
+        this.#sendToPptr({id: msg.id, sessionId, result: {}});
+      }
+      return;
+    }
+
+    const entry = this.#targets.get(targetId);
+    if (!entry) {
+      this.#replyError(msg.id, -32001, 'Target not found', sessionId);
+      return;
+    }
+
+    if (msg.id !== undefined) {
+      this.#pendingId.set(msg.id, sessionId);
+    }
+    // Strip sessionId; chobitsu speaks a flat single-session protocol.
+    entry.emitter.emit(
+      'message',
+      JSON.stringify({id: msg.id, method: msg.method, params: msg.params}),
+    );
+  };
+
+  #handleConnectionMessage = (msg: CdpMessage) => {
+    const {id, method} = msg;
+
+    switch (method) {
+      case 'Target.getBrowserContexts': {
+        this.#reply(id, {browserContextIds: []});
+        return;
+      }
+
+      case 'Target.setDiscoverTargets': {
+        this.#discovering = true;
+        this.#reply(id, {});
+        // Surface targets that connected before discovery was enabled.
+        for (const [targetId, entry] of this.#targets) {
+          this.#emitTargetCreated(
+            targetId,
+            entry.target,
+            this.#targetSessions.has(targetId),
+          );
+        }
+        return;
+      }
+
+      case 'Target.setAutoAttach': {
+        this.#autoAttaching = true;
+        this.#reply(id, {});
+        // puppeteer's ChromeTargetManager only promotes a target into the
+        // attached set (the backing store for `browser.pages()`) when it sees a
+        // `Target.attachedToTarget` event. A bare `Target.targetCreated` leaves
+        // the target merely "discovered", and puppeteer never attaches a page on
+        // its own. So we surface every known target through auto-attach, exactly
+        // as a real Chrome tab auto-attaches its page.
+        for (const targetId of this.#targets.keys()) {
+          this.#autoAttach(targetId);
+        }
+        return;
+      }
+
+      case 'Target.setRemoteLocations':
+      case 'Security.setIgnoreCertificateErrors': {
+        this.#reply(id, {});
+        return;
+      }
+
+      case 'Target.getTargets': {
+        const targetInfos = [...this.#targets].map(([targetId, entry]) => {
+          return this.#targetInfo(
+            targetId,
+            entry.target,
+            this.#targetSessions.has(targetId),
+          );
+        });
+        this.#reply(id, {targetInfos});
+        return;
+      }
+
+      case 'Target.attachToTarget': {
+        this.#attachToTarget(msg);
+        return;
+      }
+
+      case 'Target.detachFromTarget': {
+        const sessionId = (msg.params as {sessionId?: string} | undefined)
+          ?.sessionId;
+        if (sessionId) {
+          this.#dropSession(sessionId);
+        }
+        this.#reply(id, {});
+        return;
+      }
+
+      case 'Browser.getVersion': {
+        this.#reply(id, {
+          protocolVersion: '1.3',
+          product: 'Chrome/200.0.0.0',
+          revision: '',
+          userAgent: 'WebviewDevtoolsMcp',
+          jsVersion: '',
+        });
+        return;
+      }
+
+      case 'Browser.close': {
+        this.#reply(id, {});
+        return;
+      }
+
+      case 'Target.createTarget': {
+        this.#replyError(
+          id,
+          -32000,
+          'Creating pages is not supported for webview targets',
+        );
+        return;
+      }
+
+      default: {
+        // Be lenient so an unanticipated browser-level call cannot stall the
+        // handshake. Session-level traffic never reaches here.
+        if (method) {
+          logger?.(`[wdmcp] unhandled connection-level method: ${method}`);
+        }
+        this.#reply(id, {});
+        return;
+      }
+    }
+  };
+
+  /**
+   * Surface a target to puppeteer through the auto-attach mechanism. Idempotent:
+   * skips a target puppeteer already knows about (one that has any live session).
+   */
+  #autoAttach = (targetId: string) => {
+    if (this.#targetSessions.has(targetId)) {
+      return;
+    }
+    this.#openSession(targetId);
+  };
+
+  /**
+   * Allocate a session for `targetId`, record the mapping, and announce it with
+   * `Target.attachedToTarget`. Returns the new sessionId, or undefined when the
+   * target is unknown.
+   */
+  #openSession = (targetId: string): string | undefined => {
+    const entry = this.#targets.get(targetId);
+    if (!entry) {
+      return undefined;
+    }
+
+    const sessionId = `${SESSION_PREFIX}${targetId}_${++this.#sessionSeq}`;
+    this.#sessionToTarget.set(sessionId, targetId);
+    let sessions = this.#targetSessions.get(targetId);
+    if (!sessions) {
+      sessions = new Set();
+      this.#targetSessions.set(targetId, sessions);
+    }
+    sessions.add(sessionId);
+
+    this.#sendToPptr({
+      method: 'Target.attachedToTarget',
+      params: {
+        sessionId,
+        targetInfo: this.#targetInfo(targetId, entry.target, true),
+        waitingForDebugger: false,
+      },
+    });
+    return sessionId;
+  };
+
+  #attachToTarget = (msg: CdpMessage) => {
+    const targetId = (msg.params as {targetId?: string} | undefined)?.targetId;
+    // Order matters: puppeteer's Connection creates the CDPSession when it sees
+    // `Target.attachedToTarget`, then resolves attachToTarget by looking that
+    // session up. #openSession emits the event; we then send the response.
+    const sessionId = targetId ? this.#openSession(targetId) : undefined;
+    if (!sessionId) {
+      this.#replyError(msg.id, -32602, 'No target with given id found');
+      return;
+    }
+    this.#reply(msg.id, {sessionId});
+  };
+
+  #dropSession = (sessionId: string) => {
+    const targetId = this.#sessionToTarget.get(sessionId);
+    this.#sessionToTarget.delete(sessionId);
+    if (targetId) {
+      const sessions = this.#targetSessions.get(targetId);
+      sessions?.delete(sessionId);
+      if (sessions && sessions.size === 0) {
+        this.#targetSessions.delete(targetId);
+      }
+    }
+    // Drop any in-flight ids owned by this session.
+    for (const [pid, sid] of this.#pendingId) {
+      if (sid === sessionId) {
+        this.#pendingId.delete(pid);
+      }
+    }
+    this.#sendToPptr({
+      method: 'Target.detachedFromTarget',
+      params: {sessionId},
+    });
+  };
+
+  #onPptrToChiiClose = () => {
+    // puppeteer disconnected. Disposing the chii server is intentionally not
+    // done here yet (the server is shared / owns the static target.js route).
+  };
+
+  // #endregion
+
+  // #region helpers
+
+  #targetInfo = (
+    targetId: string,
+    target: ChiiTarget,
+    attached: boolean,
+  ): TargetInfo => {
+    return {
+      targetId,
+      type: 'page',
+      title: target.title || '',
+      url: target.url || '',
+      attached,
+      canAccessOpener: false,
+    };
+  };
+
+  #emitTargetCreated = (
+    targetId: string,
+    target: ChiiTarget,
+    attached: boolean,
+  ) => {
+    this.#sendToPptr({
+      method: 'Target.targetCreated',
+      params: {targetInfo: this.#targetInfo(targetId, target, attached)},
+    });
+  };
+
+  #flushFirstTargetWaiters = () => {
+    if (this.#firstTargetWaiters.length === 0) {
+      return;
+    }
+    const waiters = this.#firstTargetWaiters;
+    this.#firstTargetWaiters = [];
+    for (const waiter of waiters) {
+      waiter();
+    }
+  };
+
+  #reply = (id: number | undefined, result: Record<string, unknown>) => {
+    if (id !== undefined) {
+      this.#sendToPptr({id, result});
+    }
+  };
+
+  #replyError = (
+    id: number | undefined,
+    code: number,
+    message: string,
+    sessionId?: string,
+  ) => {
+    if (id === undefined) {
+      return;
+    }
+    const msg: CdpMessage = {id, error: {code, message}};
+    if (sessionId) {
+      msg.sessionId = sessionId;
+    }
+    this.#sendToPptr(msg);
+  };
+
+  #sendToPptr = (msg: CdpMessage | Record<string, unknown>) => {
+    this.transport.sendMessageToPptr(JSON.stringify(msg));
+  };
+
+  // #endregion
+}
